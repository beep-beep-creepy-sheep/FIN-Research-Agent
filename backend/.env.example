DATABASE_URL=sqlite:///../data/finresearch.sqlite
DATA_DIR=../data
DOCUMENTS_DIR=../data/documents
RAW_DATA_DIR=../data/raw
REPORTS_DIR=../data/reports

LLM_ENABLED=false
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_CONNECT_TIMEOUT_SECONDS=2
OLLAMA_GENERATE_TIMEOUT_SECONDS=45
OLLAMA_KEEP_ALIVE=10m
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

AGENT_REACH_ENABLED=false
EXA_ENABLED=false

OFFICIAL_SOURCES_ENABLED=true
OFFICIAL_SOURCE_REQUEST_TIMEOUT_SECONDS=10
OFFICIAL_SOURCE_READ_TIMEOUT_SECONDS=30
OFFICIAL_SOURCE_MAX_DOWNLOAD_BYTES=52428800
OFFICIAL_SOURCE_MAX_PDF_BYTES=52428800
OFFICIAL_SOURCE_MAX_PDF_PAGES=300
OFFICIAL_SOURCE_RATE_LIMIT_PER_SECOND=0.5
OFFICIAL_SOURCE_ALLOWED_DOMAINS_CNINFO=www.cninfo.com.cn,static.cninfo.com.cn
OFFICIAL_SOURCE_ALLOWED_DOMAINS_SSE=www.sse.com.cn,static.sse.com.cn
OFFICIAL_SOURCE_ALLOWED_DOMAINS_SZSE=www.szse.cn,disc.static.szse.cn
OFFICIAL_SOURCE_ALLOWED_DOMAINS_BSE=www.bse.cn
OFFICIAL_SOURCE_ALLOWED_DOMAINS_SEC=www.sec.gov,sec.gov
RUN_LIVE_SOURCE_TESTS=false
BENCHMARK_SELECTION_VERSION=stage3-benchmark-v1
ALLOW_FIXTURE_OFFICIAL_SOURCES=true
